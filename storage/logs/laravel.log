  {
    \"type\": \"situational_judgement\",
    \"topic\": \"Professionalism & Confidentiality\",
    \"stem\": \"You are a medical student on placement. During a lunch break in the staff room, you overhear a senior doctor openly making critical and somewhat mocking remarks about a patient's lifestyle choices and their contribution to their current illness, in front of other staff members.\",
    \"passage\": null,
    \"options\": [
